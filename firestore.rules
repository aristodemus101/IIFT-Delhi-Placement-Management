rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: fetch the caller's role document
    function roleData() {
      return get(/databases/$(database)/documents/roles/$(request.auth.uid)).data;
    }

    function isAuthed()  { return request.auth != null; }
    function isAdmin()        { return isAuthed() && roleData().role == 'admin'; }
    function isMasterAdmin()  { return isAuthed() && roleData().isMasterAdmin == true; }
    function hasRole()        { return isAuthed() && roleData().role in ['admin', 'viewer']; }

    // ── Students ────────────────────────────────────────────────────────────
    // Viewers: read only. Admins: read + write.
    // Direct writes by admins are allowed; the approval workflow is enforced
    // at the app layer and backed by the immutable auditLog.
    match /students/{id} {
      allow read:  if hasRole();
      allow write: if isAdmin();
    }

    // ── Pending Changes ─────────────────────────────────────────────────────
    // Only admins can propose (create) or review (update) changes.
    // An admin cannot approve/reject their own proposal (enforced here AND in app).
    match /pendingChanges/{id} {
      allow read: if hasRole();

      allow create: if isAdmin()
        && request.resource.data.proposedBy == request.auth.uid
        && request.resource.data.status    == 'pending';

      // Review path: a different admin approves/rejects pending proposals.
      // Withdraw path: proposer withdraws their own pending proposal.
      allow update: if isAdmin()
        && resource.data.status == 'pending'
        && request.resource.data.proposedBy == resource.data.proposedBy
        && (
          (
            resource.data.proposedBy != request.auth.uid
            && request.resource.data.status in ['approved', 'rejected']
          )
          ||
          (
            resource.data.proposedBy == request.auth.uid
            && request.resource.data.status == 'withdrawn'
            && request.resource.data.withdrawnBy == request.auth.uid
          )
        );
    }

    // ── Roles ───────────────────────────────────────────────────────────────
    // Any authenticated user can read roles (needed to check their own role).
    // Any authenticated user can create their OWN role doc on first login.
    // Only the master admin can promote/demote others.
    match /roles/{uid} {
      allow read:   if isAuthed();
      allow create: if isAuthed() && request.auth.uid == uid;
      allow update: if isMasterAdmin();
      allow delete: if isMasterAdmin();
    }

    // ── Audit Log ───────────────────────────────────────────────────────────
    // Immutable. Admins can append; nobody can modify or delete.
    match /auditLog/{id} {
      allow read:          if hasRole();
      allow create:        if isAdmin();
      allow update, delete: if false;
    }

    // ── Config ──────────────────────────────────────────────────────────────
    // Stores shared app config (e.g. playground sheet URL). All users can read;
    // only admins can write.
    match /config/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    // ── Templates ───────────────────────────────────────────────────────────
    // Column-mapping templates are non-sensitive; any authed user can manage them.
    match /templates/{id} {
      allow read, write: if isAuthed();
    }

    // ── User Preferences ─────────────────────────────────────────────────────
    // Per-user UI preferences (column visibility, sorting, etc.).
    match /userPrefs/{uid} {
      allow read, write: if isAuthed() && request.auth.uid == uid;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
